    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ts-safeql/plugin-utils": "workspace:*",
    "@ts-safeql/shared": "workspace:*",
    "fp-ts": "^2.16.9",
    "pg-connection-string": "2.7.0",
    "postgres": "3.4.7",
    "ts-pattern": "^5.6.2"
  },
  "devDependencies": {
    "@ts-safeql/test-utils": "workspace:*",
    "@types/node": "^22.13.13",
    "typescript": "^5.8.2",
    "unbuild": "^3.5.0",
    "vitest": "^3.0.9"
  }
}
