{
  "name": "@ts-safeql/connection-manager",
  "version": "4.2.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "main": "dist/index.cjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
