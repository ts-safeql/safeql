  "dependencies": {
    "postgres": "catalog:",
    "tsx": "catalog:"
  },
  "peerDependencies": {
    "@typescript-eslint/utils": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@typescript-eslint/utils": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  }
