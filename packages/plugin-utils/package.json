{
  "name": "@ts-safeql/plugin-utils",
  "version": "5.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ts-safeql/safeql.git",
    "directory": "packages/plugin-utils"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "main": "dist/index.cjs",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts",
        "default": "./dist/index.d.ts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./testing": {
      "types": {
        "import": "./dist/plugin-test-driver.d.mts",
        "require": "./dist/plugin-test-driver.d.cts",
        "default": "./dist/plugin-test-driver.d.ts"
      },
      "import": "./dist/plugin-test-driver.mjs",
      "require": "./dist/plugin-test-driver.cjs"
    }
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "publint": "publint",
    "typecheck": "tsc -b",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@typescript-eslint/utils": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "unbuild": "catalog:"
  },
  "dependencies": {
    "postgres": "catalog:"
  },
  "peerDependencies": {
    "@typescript-eslint/utils": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@typescript-eslint/utils": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  }
}
