{
  "name": "@ts-safeql/plugin-auth-aws",
  "version": "4.3.0",
  "license": "MIT",
  "repository": "https://github.com/ts-safeql/safeql/tree/master/packages/plugins/auth-aws",
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "main": "dist/index.cjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "typecheck": "tsc -b",
    "test": "vitest --run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "unbuild": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@aws-sdk/credential-providers": "^3.0.0",
    "@aws-sdk/rds-signer": "^3.0.0",
    "@ts-safeql/plugin-utils": "workspace:*",
    "postgres": "catalog:"
  }
}
